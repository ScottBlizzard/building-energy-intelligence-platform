APP_ENV=development
DEBUG=true
DATA_FILE=data/samples/energy_records.csv
KNOWLEDGE_BASE_DIR=knowledge_base
WORK_ORDER_FILE=data/runtime/work_orders.json
ALLOWED_ORIGINS=*

# 数据库（可选）。留空 = 使用 JSON/CSV 文件存储（默认，零依赖、可离线运行）。
# 配置后启用 MySQL 持久化（工单/预算/沙盘/能耗读数入库）：
#   DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/energy?charset=utf8mb4
# 首次使用先建表并导入数据集： cd backend && python -m app.db.init_db
DATABASE_URL=
VITE_API_BASE_URL=/api/v1

# Optional external LLM integration.
# Never put real API keys in this template. Copy this file to .env locally.
LLM_ENABLED=false
LLM_PROVIDER=local
LLM_BASE_URL=http://127.0.0.1:10531/v1
LLM_MODEL=gpt-5.4
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=20
LLM_MAX_TOKENS=768
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.7
LLM_TEST_PROVIDERS=nvidia,groq,siliconflow

# Provider-specific key variables can be used instead of LLM_API_KEY.
NVIDIA_API_KEY=replace_with_local_secret
GROQ_API_KEY=replace_with_local_secret
OPENROUTER_API_KEY=replace_with_local_secret
TOGETHER_API_KEY=replace_with_local_secret
SILICONFLOW_API_KEY=replace_with_local_secret
ALIBABA_API_KEY=replace_with_local_secret
GEMINI_API_KEY=replace_with_local_secret
OPENAI_API_KEY=replace_with_local_secret
LOCAL_LLM_API_KEY=not-needed
